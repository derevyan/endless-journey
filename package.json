{
  "name": "journey",
  "private": true,
  "version": "0.3.0",
  "description": "A visual journey builder, simulator, and runtime engine for messaging and AI-driven user journeys. A personal, vibe-coded project shared as-is under MIT.",
  "license": "MIT",
  "author": "Andrew Derevo",
  "repository": {
    "type": "git",
    "url": "https://github.com/derevyan/journey.git"
  },
  "keywords": [
    "journey-builder",
    "workflow-automation",
    "react-flow",
    "llm",
    "ai-agents",
    "telegram",
    "turborepo"
  ],
  "type": "module",
  "packageManager": "pnpm@10.25.0",
  "scripts": {
    "prepare": "husky",
    "dev": "turbo run dev",
    "dev:watch": "turbo watch dev",
    "dev:api": "pnpm --filter @journey/api dev",
    "dev:api:watch": "pnpm --filter @journey/api dev:watch",
    "dev:mcp": "pnpm --filter @journey/mcp-service dev",
    "dev:web": "pnpm --filter @journey/web dev",
    "build": "turbo run build",
    "preview": "turbo run preview",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "turbo run test --concurrency 1",
    "test:quick": "pnpm --filter @journey/schemas test && pnpm --filter @journey/engine test:core",
    "test:unit": "turbo run test:unit",
    "test:unit:all": "turbo run test --filter=@journey/schemas --filter=@journey/engine --filter=@journey/llm --filter=@journey/mindstate && pnpm --filter @journey/web test:unit",
    "test:backend": "pnpm --filter @journey/schemas test && pnpm --filter @journey/llm test && pnpm --filter @journey/mindstate test && pnpm --filter @journey/engine-integrations test && pnpm --filter @journey/engine test && pnpm --filter @journey/api test",
    "test:backend:fuzzy": "pnpm test:backend && pnpm test:fuzzy",
    "test:integration": "pnpm --filter @journey/llm test && pnpm --filter @journey/api test && pnpm --filter @journey/engine test:slow",
    "test:api": "pnpm --filter @journey/api test",
    "test:engine": "pnpm --filter @journey/engine test",
    "test:mindstate": "pnpm --filter @journey/mindstate test",
    "test:web": "pnpm --filter @journey/web test",
    "test:schemas": "pnpm --filter @journey/schemas test",
    "test:llm": "pnpm --filter @journey/llm test",
    "test:mcp": "pnpm --filter @journey/mcp-service test",
    "test:fuzzy": "pnpm --filter @journey/engine test:fuzzy:all",
    "test:e2e": "pnpm --filter @journey/web test:e2e",
    "test:all": "pnpm test:backend && pnpm --filter @journey/web test:unit && pnpm test:e2e",
    "test:e2e:journey": "pnpm --filter @journey/web test:e2e:journey",
    "test:e2e:nodes": "pnpm --filter @journey/web test:e2e:nodes",
    "test:e2e:node-editors": "pnpm --filter @journey/web test:e2e:node-editors",
    "test:e2e:edge-editor": "pnpm --filter @journey/web test:e2e:edge-editor",
    "test:e2e:simulator": "pnpm --filter @journey/web test:e2e:simulator",
    "test:e2e:users": "pnpm --filter @journey/web test:e2e:users",
    "test:e2e:settings": "pnpm --filter @journey/web test:e2e:settings",
    "test:e2e:vars": "pnpm --filter @journey/web test:e2e:vars",
    "test:e2e:tags": "pnpm --filter @journey/web test:e2e:tags",
    "test:e2e:personas": "pnpm --filter @journey/web test:e2e:personas",
    "test:e2e:events": "pnpm --filter @journey/web test:e2e:events",
    "test:e2e:crm": "pnpm --filter @journey/web test:e2e:crm",
    "test:e2e:teleport": "pnpm --filter @journey/web test:e2e:teleport",
    "test:e2e:mindstate": "pnpm --filter @journey/web test:e2e:mindstate",
    "test:api:mindstate": "pnpm --filter @journey/api test:mindstates",
    "test:e2e:org": "pnpm --filter @journey/web test:e2e:org",
    "test:e2e:questionnaire": "pnpm --filter @journey/web test:e2e:questionnaire",
    "test:e2e:agent-workflows": "pnpm --filter @journey/web test:e2e:agent",
    "test:e2e:workflows": "pnpm --filter @journey/web test:e2e:agent-workflows",
    "test:e2e:prompts": "pnpm --filter @journey/web test:e2e:prompts",
    "test:e2e:followup": "pnpm --filter @journey/web test:e2e:followup",
    "test:e2e:plugins": "pnpm --filter @journey/web test:e2e:plugins",
    "test:e2e:media": "pnpm --filter @journey/web test:e2e:media",
    "test:e2e:impersonate": "pnpm --filter @journey/web test:e2e:impersonate",
    "test:impersonate": "pnpm --filter @journey/web test:impersonate",
    "test:agents": "pnpm test:agents:unit && pnpm test:agents:integration",
    "test:agents:unit": "pnpm --filter @journey/engine test agent-handler",
    "test:agents:integration": "pnpm --filter @journey/api test agent-integration",
    "test:workflows": "pnpm --filter @journey/llm test workflow && pnpm --filter @journey/api test workflows",
    "test:workflows:unit": "pnpm --filter @journey/llm test workflow",
    "test:workflows:api": "pnpm --filter @journey/api test workflows",
    "test:personas": "pnpm --filter @journey/api test:personas && pnpm --filter @journey/web test:e2e:personas",
    "test:personas:api": "pnpm --filter @journey/api test:personas",
    "test:questionnaire": "pnpm --filter @journey/schemas test:questionnaire && pnpm --filter @journey/engine test:questionnaire",
    "test:followup": "pnpm --filter @journey/engine test:followup",
    "playground:llm": "pnpm --filter @journey/llm playground",
    "db:generate": "pnpm --filter @journey/db generate",
    "db:push": "pnpm --filter @journey/db push",
    "db:seed": "pnpm --filter @journey/db seed",
    "db:reset": "pnpm --filter @journey/db reset",
    "db:drop": "pnpm --filter @journey/db drop",
    "db:migrate": "pnpm --filter @journey/db migrate",
    "db:reset-full": "./scripts/db-reset-full.sh",
    "genesis-models": "node packages/llm/src/config/genesis-models.js",
    "blade-runner": "tsx packages/engine/bin/blade-runner.ts",
    "journey:test": "tsx packages/engine/bin/blade-runner.ts",
    "journey:analyze": "tsx packages/engine/bin/journey-analyze.ts",
    "code:stats": "./scripts/code-stats.sh",
    "clean": "rm -rf node_modules apps/*/node_modules packages/*/node_modules .turbo apps/*/.turbo packages/*/.turbo apps/*/dist packages/*/dist",
    "clean:cache": "rm -rf .turbo apps/*/.turbo packages/*/.turbo",
    "reinstall": "pnpm clean && pnpm install"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.0",
    "tsx": "^4.21.0",
    "turbo": "^2.6.3"
  }
}
