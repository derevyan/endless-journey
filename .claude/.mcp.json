{
  "mcpServers": {
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": ["@playwright/mcp@latest"],
      "env": {}
    },
    "shadcn": {
      "command": "npx",
      "args": ["shadcn@latest", "mcp"]
    },
    "Docs by LangChain": {
      "name": "Docs by LangChain",
      "url": "https://docs.langchain.com/mcp",
      "headers": {}
    }
  }
}
