# MCP Service Configuration
PORT=3002
LOG_LEVEL=info

# MCP Servers
# Each MCP server can be enabled/disabled independently
# Servers run as subprocesses via stdio transport
# All servers are DISABLED by default - enable explicitly

# Fetch Server - Fetches web content and converts to markdown
# Official MCP server (Python): requires 'uv' (brew install uv)
# https://github.com/modelcontextprotocol/servers/tree/main/src/fetch
MCP_FETCH_ENABLED=false

# Filesystem Server - File operations (read, write, list directories)
# Official MCP server (Node.js): @modelcontextprotocol/server-filesystem
# https://www.npmjs.com/package/@modelcontextprotocol/server-filesystem
MCP_FILESYSTEM_ENABLED=false
# MCP_FILESYSTEM_PATHS=/path/to/allowed/directory
