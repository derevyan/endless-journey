{
  "name": "@journey/api",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "dev:watch": "tsx watch --watch-path=../../packages src/index.ts",
    "build": "tsc",
    "start": "tsx src/index.ts",
    "preview": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:health": "vitest run -t 'Health'",
    "test:auth": "vitest run -t 'Auth'",
    "test:journeys": "vitest run -t 'Journeys'",
    "test:webhook": "vitest run -t 'Webhook'",
    "test:channels": "vitest run -t 'Channels'",
    "test:variables": "vitest run -t 'Variables'",
    "test:tags": "vitest run -t 'User Tags'",
    "test:tag-definitions": "vitest run -t 'Tag Definitions'",
    "test:sessions": "vitest run -t 'Sessions'",
    "test:users": "vitest run -t 'Channel Users'",
    "test:uploads": "vitest run -t 'Uploads'",
    "test:crm": "vitest run -t 'CRM API'",
    "test:personas": "vitest run -t 'Simulator Personas API'",
    "test:mindstates": "vitest run -t 'Mindstate'"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.953.0",
    "@bull-board/api": "^5.23.0",
    "@bull-board/hono": "^5.23.0",
    "@bull-board/ui": "^5.23.0",
    "@hono/node-server": "^1.19.7",
    "@hono/zod-validator": "^0.7.5",
    "@journey/ai-report": "workspace:*",
    "@journey/db": "workspace:*",
    "@journey/engine": "workspace:*",
    "@journey/engine-integrations": "workspace:*",
    "@journey/infra": "workspace:*",
    "@journey/llm": "workspace:*",
    "@journey/logger": "workspace:*",
    "@journey/mcp": "workspace:*",
    "@journey/mindstate": "workspace:*",
    "@journey/schemas": "workspace:*",
    "better-auth": "^1.4.7",
    "bullmq": "^5.66.1",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.11.1",
    "hono-rate-limiter": "^0.5.0",
    "ioredis": "^5.8.2",
    "postgres": "^3.4.7",
    "rate-limit-redis": "^4.3.1",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/node": "^22.19.3",
    "tsx": "^4.21.0",
    "typescript": "~5.8.3",
    "vitest": "^2.1.9"
  }
}
