# Environment
NODE_ENV=development
LOG_LEVEL=trace

# Database
DATABASE_URL=postgres://journey:journey_dev@localhost:5432/journey

# Database Connection Pool (optional, has sensible defaults)
# DB_POOL_MAX=20              # Maximum connections in pool
# DB_IDLE_TIMEOUT=30          # Close idle connections after N seconds
# DB_CONNECT_TIMEOUT=10       # Connection timeout in seconds
# DB_MAX_LIFETIME=1800        # Max connection lifetime in seconds (30 min)

# Redis (for BullMQ timer service, session cache, rate limiting)
REDIS_URL=redis://localhost:6379

# Better Auth - Secret key for session encryption (minimum 32 characters)
# Generate with: openssl rand -base64 32
# REQUIRED in all environments (will fail to start without it)
BETTER_AUTH_SECRET=your_better_auth_secret_here

# Mock Authentication (development/testing only)
# Set to "true" to enable X-Mock-User-Id header for bypassing auth
# WARNING: Never enable this in production or staging environments!
ALLOW_MOCK_AUTH=true

# URLs
FRONTEND_URL=http://localhost:3000
PORT=3001
# API_URL=http://localhost:3001  # Optional, defaults to http://localhost:PORT

# Webhook base URL (for Telegram bot webhooks)
# Use ngrok or similar for local development
WEBHOOK_BASE_URL=https://your-tunnel.ngrok-free.dev

# MinIO (S3-compatible storage for media uploads)
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=journey-media

# LLM Provider API Keys
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GROQ_API_KEY=your_groq_api_key_here
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
CEREBRAS_API_KEY=your_cerebras_api_key_here

# =============================================================================
# MCP (Model Context Protocol) Tools - External AI Agent Tools
# =============================================================================
# MCP servers run as external processes and provide tools for AI agents.
# Servers are enabled by default unless explicitly disabled.

# Fetch Server - Fetches web content and converts to markdown
# Uses: @anthropics/mcp-server-fetch (official Anthropic server)
# MCP_FETCH_ENABLED=true     # Set to "false" to disable

# =============================================================================
# Rate Limiting (optional, has sensible defaults)
# =============================================================================
# Rate limiting is DISABLED when ALLOW_MOCK_AUTH=true (dev/test mode)
# In production, these limits protect against abuse and DoS attacks

# HTTP Request Rate Limits
# RATE_LIMIT_GLOBAL=100       # Global: 100 requests per minute per user/IP
# RATE_LIMIT_AUTH=10          # Auth endpoints: 10 requests per 15 minutes per IP
# RATE_LIMIT_WEBHOOK=200      # Webhooks: 200 requests per minute per channel

# Event Publishing Rate Limits (token bucket)
# RATE_LIMIT_EVENTS_MAX_TOKENS=1000    # Max tokens in bucket per org
# RATE_LIMIT_EVENTS_REFILL_RATE=1000   # Tokens added per interval
# RATE_LIMIT_EVENTS_INTERVAL=60        # Refill interval in seconds
# RATE_LIMIT_SSE_MAX_CONNECTIONS=10    # Max SSE connections per user

# =============================================================================
# Circuit Breakers (optional, has sensible defaults)
# =============================================================================
# Circuit breakers protect against cascading failures when external services
# are down. When error threshold is exceeded, the circuit "opens" and requests
# fail fast instead of timing out.
#
# States: closed (normal) → open (failing fast) → half-open (testing recovery)

# LLM Service Circuit Breaker
# CB_LLM_ENABLED=true                  # Enable/disable circuit breaker
# CB_LLM_TIMEOUT=30000                 # Request timeout in ms (30s)
# CB_LLM_ERROR_THRESHOLD=50            # Error percentage to trip circuit (50%)
# CB_LLM_VOLUME_THRESHOLD=10           # Min requests before calculating error rate
# CB_LLM_RESET_TIMEOUT=60000           # Time before attempting reset (60s)

# Webhook Circuit Breaker (per-domain isolation)
# CB_WEBHOOK_ENABLED=true              # Enable/disable circuit breaker
# CB_WEBHOOK_TIMEOUT=30000             # Request timeout in ms (30s)
# CB_WEBHOOK_ERROR_THRESHOLD=60        # Error percentage to trip circuit (60%)
# CB_WEBHOOK_VOLUME_THRESHOLD=10       # Min requests before calculating error rate
# CB_WEBHOOK_RESET_TIMEOUT=30000       # Time before attempting reset (30s)

# Telegram API Circuit Breaker
# CB_TELEGRAM_ENABLED=true             # Enable/disable circuit breaker
# CB_TELEGRAM_TIMEOUT=15000            # Request timeout in ms (15s)
# CB_TELEGRAM_ERROR_THRESHOLD=50       # Error percentage to trip circuit (50%)
# CB_TELEGRAM_VOLUME_THRESHOLD=10      # Min requests before calculating error rate
# CB_TELEGRAM_RESET_TIMEOUT=45000      # Time before attempting reset (45s)

# CRM/Other Services Circuit Breaker (fallback defaults)
# CB_CRM_ENABLED=true                  # Enable/disable circuit breaker
# CB_CRM_TIMEOUT=15000                 # Request timeout in ms (15s)
# CB_CRM_ERROR_THRESHOLD=50            # Error percentage to trip circuit (50%)
# CB_CRM_VOLUME_THRESHOLD=10           # Min requests before calculating error rate
# CB_CRM_RESET_TIMEOUT=30000           # Time before attempting reset (30s)