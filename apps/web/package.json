{
  "name": "@journey/web",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --report-unused-disable-directives --max-warnings 0",
    "test": "NODE_ENV=test vitest run && NODE_ENV=test playwright test",
    "test:unit": "NODE_ENV=test vitest run",
    "test:e2e": "NODE_ENV=test playwright test",
    "test:e2e:vars": "NODE_ENV=test playwright test tests/variables.spec.ts",
    "test:e2e:tags": "NODE_ENV=test playwright test tests/user-tags.spec.ts",
    "test:e2e:settings": "NODE_ENV=test playwright test tests/settings-profile.spec.ts tests/settings-organisation.spec.ts tests/settings-tags.spec.ts",
    "test:e2e:nodes": "NODE_ENV=test playwright test tests/node-editors.spec.ts",
    "test:e2e:node-editors": "NODE_ENV=test playwright test --grep @node-editors",
    "test:e2e:edge-editor": "NODE_ENV=test playwright test --grep @edge-editor",
    "test:e2e:media": "NODE_ENV=test playwright test tests/media-upload.spec.ts",
    "test:e2e:journey": "NODE_ENV=test playwright test tests/journey-visualizer.spec.ts",
    "test:e2e:personas": "NODE_ENV=test playwright test tests/simulator-personas.spec.ts",
    "test:e2e:org": "NODE_ENV=test playwright test tests/organisation-switcher.spec.ts",
    "test:e2e:events": "NODE_ENV=test playwright test tests/events-logs.spec.ts",
    "test:e2e:crm": "NODE_ENV=test playwright test tests/crm.spec.ts",
    "test:e2e:teleport": "NODE_ENV=test playwright test tests/teleport-node.spec.ts",
    "test:e2e:mindstate": "NODE_ENV=test playwright test tests/mindstate-builder-*.spec.ts",
    "test:e2e:followup": "NODE_ENV=test playwright test tests/follow-up-plugin.spec.ts",
    "test:e2e:questionnaire": "NODE_ENV=test playwright test tests/questionnaire-node.spec.ts",
    "test:e2e:agent": "NODE_ENV=test playwright test --grep @ai-agent",
    "test:e2e:agent-workflows": "NODE_ENV=test playwright test tests/agent-workflows.spec.ts",
    "test:e2e:prompts": "NODE_ENV=test playwright test tests/prompts.spec.ts",
    "test:e2e:plugins": "NODE_ENV=test playwright test tests/plugin-system.spec.ts tests/follow-up-plugin.spec.ts",
    "test:e2e:impersonate": "NODE_ENV=test playwright test tests/impersonate-playback.spec.ts",
    "test:impersonate": "NODE_ENV=test vitest run src/features/users/hooks/__tests__/use-user-impersonation.test.ts src/features/journey/simulator/hooks/__tests__/playback-edge-highlighting.e2e.test.ts src/features/journey/session-player/__tests__/playback.e2e.test.ts && pnpm run test:e2e:impersonate"
  },
