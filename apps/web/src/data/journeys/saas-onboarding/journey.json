    {
      "id": "plan-router",
      "data": {
        "type": "condition",
        "label": "$content:plan-router.label",
        "branches": [
          {
            "id": "basic",
            "label": "$content:plan-router.branches.0.label",
            "isDefault": true
          },
          {
            "id": "pro",
            "label": "$content:plan-router.branches.1.label"
          },
          {
            "id": "enterprise",
            "label": "$content:plan-router.branches.2.label"
          }
        ],
        "expression": "selectedPlan && (selectedPlan.includes('Enterprise') || selectedPlan.includes('enterprise')) ? 'enterprise' : (selectedPlan && (selectedPlan.includes('Pro') || selectedPlan.includes('pro')) ? 'pro' : 'basic')"
      },
      "type": "custom",
      "metadata": {
        "notes": "Routes to plan-specific tips based on selectedPlan variable. Expression returns branch id directly.",
        "custom": {},
        "status": "active",
        "version": "1.0.0",
