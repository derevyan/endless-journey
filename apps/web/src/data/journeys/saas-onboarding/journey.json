    {
      "id": "crm-sync",
      "data": {
        "url": "https://api.example.com/crm/users/{{user.id}}/engagement",
        "auth": {
          "type": "bearer",
          "token": "{{secrets.CRM_API_TOKEN}}"
        },
        "body": "{\"userId\": \"{{user.id}}\", \"plan\": \"{{context.selectedPlan}}\", \"challenge\": \"{{context.userChallenge}}\", \"stage\": \"onboarding_complete\", \"engagementScore\": {{context.engagementScore}}, \"timestamp\": \"{{context.currentTime}}\"}",
        "type": "webhook",
        "label": "$content:crm-sync.label",
        "method": "POST",
        "content": "$content:crm-sync.content",
        "headers": {
          "X-Source": "journey-engine",
          "Content-Type": "application/json"
        },
        "storeAs": "crmSyncId",
        "tagAction": {
          "tags": {
            "add": [
              "crm-synced"
            ],
            "remove": [
              "exploring"
            ]
          }
        },
        "timeoutMs": 10000,
        "retryCount": 2,
        "successPath": "$.data.syncId",
        "mockResponse": {
          "body": {
            "data": {
              "syncId": "sync_demo_12345",
              "message": "User engagement synced successfully"
            },
            "success": true
          },
          "delay": 500,
