      "data": {
        "type": "message",
        "label": "$content:feature-intro.label",
        "buttons": [
          {
            "id": "btn-basic-1",
            "text": "$content:feature-intro.buttons.0.text",
            "targetNodeId": "saas-helper-agent"
          },
          {
            "id": "btn-pro-1",
            "text": "$content:feature-intro.buttons.1.text",
            "targetNodeId": "saas-helper-agent"
          },
          {
            "id": "btn-enterprise-1",
            "text": "$content:feature-intro.buttons.2.text",
            "targetNodeId": "saas-helper-agent"
          }
        ],
        "content": "$content:feature-intro.content",
        "plugins": [
          {
            "label": "Follow-Up",
            "steps": [
              {
                "id": "step-1",
                "delay": {
                  "hours": 2
                },
                "buttons": [
                  {
                    "id": "btn-basic-2",
                    "text": "$content:feature-intro.plugins.0.steps.0.buttons.0.text",
                    "targetNodeId": "saas-helper-agent"
                  },
                  {
                    "id": "btn-pro-2",
                    "text": "$content:feature-intro.plugins.0.steps.0.buttons.1.text",
                    "targetNodeId": "saas-helper-agent"
                  },
                  {
                    "id": "btn-enterprise-2",
                    "text": "$content:feature-intro.plugins.0.steps.0.buttons.2.text",
                    "targetNodeId": "saas-helper-agent"
                  }
                ],
                "content": "$content:feature-intro.plugins.0.steps.0.content",
                "exitOnTimeout": false
              },
              {
                "id": "step-2",
                "delay": {
                  "hours": 24
                },
                "buttons": [
                  {
                    "id": "btn-basic-3",
                    "text": "$content:feature-intro.plugins.0.steps.1.buttons.0.text",
                    "targetNodeId": "saas-helper-agent"
                  },
                  {
                    "id": "btn-pro-3",
                    "text": "$content:feature-intro.plugins.0.steps.1.buttons.1.text",
                    "targetNodeId": "saas-helper-agent"
                  },
                  {
                    "id": "btn-enterprise-3",
                    "text": "$content:feature-intro.plugins.0.steps.1.buttons.2.text",
                    "targetNodeId": "saas-helper-agent"
                  },
                  {
                    "id": "btn-not-interested",
                    "text": "$content:feature-intro.plugins.0.steps.1.buttons.3.text",
                    "targetNodeId": "exit-graceful"
                  }
                ],
                "content": "$content:feature-intro.plugins.0.steps.1.content",
                "exitOnTimeout": false
              },
              {
                "id": "step-3",
                "delay": {
                  "hours": 24
                },
                "content": "$content:feature-intro.plugins.0.steps.2.content",
                "exitOnTimeout": true
              }
            ],
            "enabled": true,
            "exitPath": {
              "nodeId": "churned"
            },
            "pluginType": "followup",
            "cancelOnAnyResponse": true
          }
        ],
        "tagAction": {
          "tags": {
            "add": [
              "awaiting-plan-selection"
            ]
