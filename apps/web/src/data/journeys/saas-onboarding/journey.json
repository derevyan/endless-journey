              {
                "id": "exp-beginner",
                "text": "$content:needs-assessment.questions.0.buttons.0.text"
              },
              {
                "id": "exp-intermediate",
                "text": "$content:needs-assessment.questions.0.buttons.1.text"
              },
              {
                "id": "exp-expert",
                "text": "$content:needs-assessment.questions.0.buttons.2.text"
              }
            ],
            "content": "$content:needs-assessment.questions.0.content",
            "required": true,
            "responseType": "buttons"
          },
          {
            "id": "q-goal",
            "buttons": [
              {
                "id": "goal-automate",
                "text": "$content:needs-assessment.questions.1.buttons.0.text"
              },
              {
                "id": "goal-engage",
                "text": "$content:needs-assessment.questions.1.buttons.1.text"
              },
              {
                "id": "goal-support",
                "text": "$content:needs-assessment.questions.1.buttons.2.text"
              },
              {
                "id": "goal-other",
                "text": "$content:needs-assessment.questions.1.buttons.3.text"
              }
            ],
            "content": "$content:needs-assessment.questions.1.content",
            "required": true,
            "responseType": "buttons"
          },
          {
            "id": "q-team-size",
            "buttons": [
              {
                "id": "team-solo",
                "text": "$content:needs-assessment.questions.2.buttons.0.text"
              },
              {
                "id": "team-small",
                "text": "$content:needs-assessment.questions.2.buttons.1.text"
              },
              {
                "id": "team-medium",
                "text": "$content:needs-assessment.questions.2.buttons.2.text"
              },
              {
                "id": "team-large",
                "text": "$content:needs-assessment.questions.2.buttons.3.text"
              }
            ],
            "content": "$content:needs-assessment.questions.2.content",
            "required": true,
            "responseType": "buttons"
          }
        ],
        "tagAction": {
          "tags": {
            "add": [
              "needs-assessed"
            ]
          }
        },
        "completion": {
          "content": "$content:needs-assessment.completion.content",
          "delayBeforeTransition": 2
        },
        "storeAllAs": "needsAssessment",
        "introduction": {
          "content": "$content:needs-assessment.introduction.content"
        }
