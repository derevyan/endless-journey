    {
      "id": "notify-team",
      "data": {
        "url": "https://api.productflow.com/support/tickets",
        "body": "{\"userId\": \"{{user.id}}\", \"category\": \"{{context.issueCategory}}\", \"details\": \"{{context.technicalDetails || context.billingDetails || context.accountDetails || context.generalInquiry}}\", \"priority\": \"standard\", \"timestamp\": \"{{context.currentTime}}\"}",
        "type": "webhook",
        "label": "$content:notify-team.label",
        "method": "POST",
        "content": "$content:notify-team.content",
        "headers": {
          "Content-Type": "application/json",
          "Authorization": "Bearer {{secrets.SUPPORT_API_TOKEN}}"
        },
        "storeAs": "ticketId",
        "timeoutMs": 5000,
        "successPath": "$.ticket.id",
        "mockResponse": {
          "body": {
            "ticket": {
              "id": "TKT-2024-00123",
              "status": "open",
              "assignedTo": "support_team"
            }
          },
          "delay": 400,
          "enabled": true,
          "statusCode": 200
        },
        "errorHandling": "continue"
      },
      "type": "custom",
      "metadata": {
        "notes": "Webhook: Create ticket in support system",
        "custom": {},
        "status": "active",
        "version": "1.0.0",
