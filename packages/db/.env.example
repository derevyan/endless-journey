# =============================================================================
# Journey Database Environment Variables
# =============================================================================
# Copy this file to .env and update values as needed

# -----------------------------------------------------------------------------
# PostgreSQL Connection (REQUIRED)
# -----------------------------------------------------------------------------
# Format: postgres://user:password@host:port/database
DATABASE_URL=postgres://journey:journey_dev@localhost:5432/journey

# -----------------------------------------------------------------------------
# Connection Pool Configuration (OPTIONAL - sensible defaults provided)
# -----------------------------------------------------------------------------
# These settings control database connection pooling behavior.
# Adjust based on your workload and database limits.

# DB_POOL_MAX=20              # Maximum connections in pool (typical DB limit: 100-200)
# DB_IDLE_TIMEOUT=30          # Close idle connections after N seconds
# DB_CONNECT_TIMEOUT=10       # Connection timeout in seconds
# DB_MAX_LIFETIME=1800        # Max connection lifetime in seconds (30 minutes)


# The encryption key should be set via ENCRYPTION_KEY environment variable.
# Key must be 32 bytes (256 bits) - can be generated with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
ENCRYPTION_KEY=your_encryption_key_here

